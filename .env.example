# ==============================================================================
# Autonomous Code Review & Debugging Agent - Environment Variables Template
# Copy this file to '.env' and fill in your local secrets. Do not commit '.env'.
# ==============================================================================

# Backend API Configuration
BACKEND_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
JWT_SECRET_KEY=your_super_secret_jwt_key_here_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration (PostgreSQL)
# POSTGRES_PASSWORD is required — the app will not start without it.
# DATABASE_URL is computed automatically from these fields (do not set it manually).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=code_review_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# GitHub App Credentials (for Webhook Handling & PR reviews)
GITHUB_APP_ID=your_github_app_id_here
# Private key should be pasted as a single line with \n for linebreaks or referenced from file
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub OAuth Credentials (for Dashboard Login)
GITHUB_CLIENT_ID=your_oauth_client_id_here
GITHUB_CLIENT_SECRET=your_oauth_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback

# LLM Providers Configuration
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
